{
  "name": "blood-donation-server",
  "version": "1.0.0",
  "description": "This is backend application for blood donation",
  "main": "index.js",
  "scripts": {
    "start": "ts-node-dev --respawn --transpile-only ./src/server.ts",
    "migrate": "npx prisma migrate dev",
    "studio": "npx prisma studio",
    "build": "tsc",
    "postinstall": "prisma generate",
    "test": "dotenv -e .env.test -- jest",
    "test:watch": "dotenv -e .env.test -- jest --watch",
    "test:coverage": "dotenv -e .env.test -- jest --coverage",
    "test:ci": "dotenv -e .env.test -- jest --ci --runInBand"
  },
  "author": "Adnan Sarkar",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.12.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.73.4",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "http-status": "^1.7.4",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.12.3",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^7.4.4",
    "jest": "^29.7.0",
    "prisma": "^5.12.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
